; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Vessel"
run/main_scene="res://scenes/ui/engine_splash.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/stretch_mode=0
config/icon="res://icon.svg"

[autoload]

GameSession="*res://autoload/game_session.gd"
PsxSettings="*res://autoload/psx_settings.gd"
PsxSurfaceTextures="*res://autoload/psx_surface_textures.gd"
ItemDatabase="*res://autoload/item_database.gd"
InventoryManager="*res://autoload/inventory_manager.gd"
HudManager="*res://autoload/hud_manager.gd"
SaveManager="*res://autoload/save_manager.gd"
QuestManager="*res://autoload/quest_manager.gd"
InnerVoiceManager="*res://autoload/inner_voice_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"
PixelLabel="*res://autoload/pixel_label.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[importer_defaults]

texture={
"detect_3d/compress_to": 0,
"mipmaps/generate": false,
"process/size_limit": 0
}
gltf={
"animation/import": true,
"meshes/create_shadow_meshes": true,
"meshes/generate_lods": false,
"meshes/light_baking": 0
}
scene={
"animation/import": true
}

